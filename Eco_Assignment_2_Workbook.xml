12"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Direct cost item</Data></Cell></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Direct costs subtotal</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=SUM(B20:B27)"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Sum of direct costs</Data></Cell></Row><Row><Cell ss:StyleID="section"><Data ss:Type="String">Engineering and supervision</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=B28*B13"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Indirect cost</Data></Cell></Row><Row><Cell ss:StyleID="section"><Data ss:Type="String">Legal expenses</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=B18*B14"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Indirect cost; depends on FCI guess</Data></Cell></Row><Row><Cell ss:StyleID="section"><Data ss:Type="String">Construction expense and contractor fee</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=B18*B15"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Indirect cost; depends on FCI guess</Data></Cell></Row><Row><Cell ss:StyleID="section"><Data ss:Type="String">Contingency</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=B18*B16"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Indirect cost; depends on FCI guess</Data></Cell></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Indirect costs subtotal</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=SUM(B29:B32)"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Sum of indirect costs</Data></Cell></Row><Row><Cell ss:StyleID="header"><Data ss:Type="String">Computed fixed capital investment</Data></Cell><Cell ss:StyleID="formulaCurrency" ss:Formula="=B28+B33"><Data ss:Type="Number"></Data></Cell><Cell><Data ss:Type="String">Target value for the FCI guess</Data></Cell></Row><Row><Cell ss:StyleID="header"><Data ss:Type="S